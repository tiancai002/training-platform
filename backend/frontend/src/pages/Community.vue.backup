<template>
  <div class="community-page">
    <!-- Hero Section -->
    <section class="community-hero">
      <div class="hero-content">
        <div class="hero-icon">💬</div>
        <h1>学习社区</h1>
        <p class="hero-subtitle">技术交流 · 经验分享 · 资源互助 · 共同成长</p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="stat-value">{{ posts.length }}</span>
            <span class="stat-label">帖子</span>
          </div>
          <div class="hero-stat">
            <span class="stat-value">{{ totalComments }}</span>
            <span class="stat-label">评论</span>
          </div>
          <div class="hero-stat">
            <span class="stat-value">{{ categories.length }}</span>
            <span class="stat-label">分类</span>
          </div>
          <div class="hero-stat">
            <span class="stat-value">500+</span>
            <span class="stat-label">用户</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter & Actions -->
    <section class="action-section">
      <div class="action-container">
        <el-tabs v-model="activeCategory" @change="loadPosts" class="category-tabs">
          <el-tab-pane label="🏠 全部" :name="0" />
          <el-tab-pane v-for="cat in categories" :key="cat.id" :label="getCategoryIcon(cat.name) + ' ' + cat.name" :name="cat.id" />
        </el-tabs>
        
        <div class="action-buttons">
          <el-button type="primary" @click="showPostDialog = true" size="large" round>
            <el-icon><Edit /></el-icon>
            发布帖子
          </el-button>
        </div>
      </div>
    </section>

    <!-- Posts List -->
    <section class="posts-section">
      <div class="posts-container" v-loading="loading">
        <!-- Pinned Posts -->
        <div v-if="pinnedPosts.length" class="pinned-section">
          <div class="section-label">
            <el-icon><Star /></el-icon>
            <span>置顶帖子</span>
          </div>
          <div class="post-cards">
            <div
              v-for="post in pinnedPosts"
              :key="post.id"
              class="post-card pinned"
              @click="viewPost(post)"
            >
              <div class="post-card-content">
                <div class="post-badge">📌</div>
                <div class="post-main">
                  <h3 class="post-title">{{ post.title }}</h3>
                  <div class="post-meta">
                    <el-tag type="warning" size="small">置顶</el-tag>
                    <span class="meta-item">
                      <el-icon><User /></el-icon>
                      {{ post.author?.nickname || '未知用户' }}
                    </span>
                    <span class="meta-item">
                      <el-icon><Clock /></el-icon>
                      {{ formatDate(post.created_at) }}
                    </span>
                  </div>
                </div>
                <div class="post-stats">
                  <div class="stat-item">
                    <el-icon><Document /></el-icon>
                    <span>{{ post.view_count }}</span>
                  </div>
                  <div class="stat-item">
                    <el-icon><Star /></el-icon>
                    <span>{{ post.like_count }}</span>
                  </div>
                  <div class="stat-item">
                    <el-icon><ChatDotRound /></el-icon>
                    <span>{{ post.comment_count }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Normal Posts -->
        <div class="normal-section">
          <div class="section-label" v-if="pinnedPosts.length">
            <el-icon><Document /></el-icon>
            <span>最新帖子</span>
          </div>
          <div class="post-cards">
            <div
              v-for="post in normalPosts"
              :key="post.id"
              class="post-card"
              @click="viewPost(post)"
            >
              <div class="post-card-content">
                <div class="post-main">
                  <h3 class="post-title">{{ post.title }}</h3>
                  <p class="post-excerpt">{{ post.content.substring(0, 120) }}...</p>
                  <div class="post-meta">
                    <div class="tags">
                      <el-tag
                        v-for="tag in (post.tags || '').split(',').slice(0,3)"
                        :key="tag"
                        size="small"
                        effect="plain"
                      >
                        {{ tag.trim() }}
                      </el-tag>
                    </div>
                    <div class="meta-info">
                      <span class="meta-item">
                        <el-avatar :size="20" :src="post.author?.avatar_url" icon="User" />
                        {{ post.author?.nickname || '未知用户' }}
                      </span>
                      <span class="meta-item">
                        <el-icon><Clock /></el-icon>
                        {{ formatTimeAgo(post.created_at) }}
                      </span>
                    </div>
                  </div>
                </div>
                <div class="post-stats">
                  <div class="stat-item views">
                    <el-icon><Document /></el-icon>
                    <span>{{ post.view_count }}</span>
                  </div>
                  <div class="stat-item likes">
                    <el-icon><Star /></el-icon>
                    <span>{{ post.like_count }}</span>
                  </div>
                  <div class="stat-item comments">
                    <el-icon><ChatDotRound /></el-icon>
                    <span>{{ post.comment_count }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Empty State -->
        <el-empty v-if="posts.length === 0" description="暂无帖子，快来发布第一个帖子吧！" />
      </div>
    </section>

    <!-- Post Detail Dialog -->
    <el-dialog
      v-model="showPostDetail"
      title="帖子详情"
      width="900px"
      class="post-detail-dialog"
      destroy-on-close
    >
      <div v-if="selectedPost" class="post-detail">
        <div class="detail-header">
          <div class="author-info">
            <el-avatar :size="50" :src="selectedPost.author?.avatar_url" icon="User" />
            <div class="author-detail">
              <div class="author-name">{{ selectedPost.author?.nickname || '未知用户' }}</div>
              <div class="author-role">{{ selectedPost.author?.role === 'instructor' ? '👨‍🏫 讲师' : '👨‍🎓 学员' }}</div>
            </div>
          </div>
          <div class="post-meta-detail">
            <span class="meta-item">
              <el-icon><Clock /></el-icon>
              {{ formatDate(selectedPost.created_at) }}
            </span>
            <span class="meta-item">
              <el-icon><Document /></el-icon>
              {{ selectedPost.view_count }} 阅读
            </span>
          </div>
        </div>

        <div class="detail-body">
          <h1 class="detail-title">{{ selectedPost.title }}</h1>
          <div class="detail-tags">
            <el-tag
              v-for="tag in (selectedPost.tags || '').split(',')"
              :key="tag"
              size="small"
            >
              {{ tag.trim() }}
            </el-tag>
          </div>
          <div class="detail-content" v-html="formatContent(selectedPost.content)"></div>
        </div>

        <div class="detail-actions">
          <el-button @click="likePost(selectedPost)" :icon="Star" round>
            点赞 {{ selectedPost.like_count }}
          </el-button>
          <el-button :icon="ChatDotRound" round>
            评论 {{ selectedPost.comment_count }}
          </el-button>
          <el-button :icon="Share" round>
            分享
          </el-button>
        </div>

        <!-- Comments Section -->
        <div class="comments-section">
          <div class="comments-header">
            <h3>💬 评论 ({{ comments.length }})</h3>
          </div>
          <div class="comments-list">
            <div v-for="comment in comments" :key="comment.id" class="comment-item">
              <el-avatar :size="40" :src="comment.author?.avatar_url" icon="User" />
              <div class="comment-content">
                <div class="comment-header">
                  <span class="comment-author">{{ comment.author?.nickname || '未知用户' }}</span>
                  <span class="comment-time">{{ formatTimeAgo(comment.created_at) }}</span>
                </div>
                <div class="comment-text">{{ comment.content }}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <template #footer>
        <el-button @click="showPostDetail = false">关闭</el-button>
      </template>
    </el-dialog>

    <!-- Create Post Dialog -->
    <el-dialog v-model="showPostDialog" title="发布新帖子" width="700px">
      <el-form :model="newPost" label-width="80px">
        <el-form-item label="标题" required>
          <el-input v-model="newPost.title" placeholder="请输入帖子标题" maxlength="100" show-word-limit />
        </el-form-item>
        <el-form-item label="分类" required>
          <el-select v-model="newPost.category_id" placeholder="请选择分类" style="width: 100%">
            <el-option v-for="cat in categories" :key="cat.id" :label="cat.name" :value="cat.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="标签">
          <el-input v-model="newPost.tags" placeholder="用逗号分隔，如：Java，面试，学习" />
        </el-form-item>
        <el-form-item label="内容" required>
          <el-input
            v-model="newPost.content"
            type="textarea"
            :rows="10"
            placeholder="分享你的学习经验、技术问题或资源..."
            maxlength="5000"
            show-word-limit
          />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="showPostDialog = false">取消</el-button>
        <el-button type="primary" @click="createPost" :loading="posting">
          <el-icon><Check /></el-icon>
          发布帖子
        </el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup>
import { ref, reactive, computed, onMounted } from 'vue'
import { communityApi } from '@/api'
import { ElMessage } from 'element-plus'
import {
  Edit, Document, User, Clock, Star, ChatDotRound, Check, Share
} from '@element-plus/icons-vue'

const activeCategory = ref(0)
const categories = ref([])
const posts = ref([])
const loading = ref(false)
const posting = ref(false)
const showPostDialog = ref(false)
const showPostDetail = ref(false)
const selectedPost = ref(null)
const comments = ref([])

const newPost = reactive({
  title: '',
  category_id: null,
  tags: '',
  content: ''
})

const totalComments = computed(() => {
  return posts.reduce((sum, post) => sum + (post.comment_count || 0), 0)
})

const pinnedPosts = computed(() => {
  return posts.filter(post => post.is_pinned)
})

const normalPosts = computed(() => {
  return posts.filter(post => !post.is_pinned)
})

const getCategoryIcon = (name) => {
  const icons = {
    '学习讨论': '📚',
    '经验分享': '💡',
    '资源分享': '📁',
    '灌水专区': '💬'
  }
  return icons[name] || '📌'
}

const loadCategories = async () => {
  try {
    categories.value = await communityApi.getCategories()
  } catch (error) {
    console.error('Failed to load categories:', error)
  }
}

const loadPosts = async () => {
  loading.value = true
  try {
    const params = { page: 1, page_size: 50 }
    if (activeCategory.value > 0) {
      params.category_id = activeCategory.value
    }
    const result = await communityApi.getPosts(params)
    posts.value = result.items || []
  } catch (error) {
    console.error('Failed to load posts:', error)
    ElMessage.error('加载帖子失败')
  } finally {
    loading.value = false
  }
}

const viewPost = async (post) => {
  selectedPost.value = post
  showPostDetail.value = true
  
  // Load comments
  try {
    // Mock comments for demo
    comments.value = [
      {
        id: 1,
        author: { nickname: '张三', avatar_url: '' },
        content: '感谢楼主分享，很有用！',
        created_at: new Date(Date.now() - 3600000).toISOString()
      },
      {
        id: 2,
        author: { nickname: '李四', avatar_url: '' },
        content: '学习了，收藏！',
        created_at: new Date(Date.now() - 7200000).toISOString()
      }
    ]
  } catch (error) {
    console.error('Failed to load comments:', error)
  }
}

const likePost = async (post) => {
  try {
    await communityApi.likePost(post.id)
    post.like_count++
    ElMessage.success('点赞成功')
  } catch (error) {
    console.error('Failed to like:', error)
  }
}

const createPost = async () => {
  if (!newPost.title || !newPost.content) {
    ElMessage.warning('请填写标题和内容')
    return
  }
  
  posting.value = true
  try {
    await communityApi.createPost({
      title: newPost.title,
      category_id: newPost.category_id || 1,
      tags: newPost.tags,
      content: newPost.content
    })
    ElMessage.success('发布成功')
    showPostDialog.value = false
    loadPosts()
    // Reset form
    newPost.title = ''
    newPost.content = ''
    newPost.tags = ''
    newPost.category_id = null
  } catch (error) {
    console.error('Failed to create post:', error)
    ElMessage.error('发布失败')
  } finally {
    posting.value = false
  }
}

const formatDate = (dateString) => {
  if (!dateString) return ''
  const date = new Date(dateString)
  return date.toLocaleDateString('zh-CN')
}

const formatTimeAgo = (dateString) => {
  if (!dateString) return ''
  const date = new Date(dateString)
  const now = new Date()
  const diff = now - date
  
  if (diff < 60000) return '刚刚'
  if (diff < 3600000) return `${Math.floor(diff / 60000)}分钟前`
  if (diff < 86400000) return `${Math.floor(diff / 3600000)}小时前`
  if (diff < 604800000) return `${Math.floor(diff / 86400000)}天前`
  return formatDate(dateString)
}

const formatContent = (content) => {
  // Convert newlines to <br> and preserve formatting
  return content.replace(/\n/g, '<br>')
}

onMounted(() => {
  loadCategories()
  loadPosts()
})
</script>

