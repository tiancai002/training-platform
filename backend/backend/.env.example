# Application
APP_NAME=培训平台
APP_VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/training_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Storage
STORAGE_PATH=/var/www/training-platform/storage
MAX_FILE_SIZE=104857600

# Live Streaming
LIVE_PLATFORM=third_party
LIVE_WEBHOOK_URL=

# Payment
STRIPE_KEY=
WECHAT_PAY_KEY=
ALIPAY_KEY=
